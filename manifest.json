{
  "manifest_version": 3,
  "name": "TimeCalc",
  "version": "1.0",
  "description": "Add & subtract time durations with smart output modes — clock, natural, work, and more.",

  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16":  "icon16.png",
      "32":  "icon32.png",
      "48":  "icon48.png",
      "128": "icon128.png"
    },
    "default_title": "TimeCalc"
  },

  "icons": {
    "16":  "icon16.png",
    "32":  "icon32.png",
    "48":  "icon48.png",
    "128": "icon128.png"
  },

  "background": {
    "service_worker": "background.js"
  },

  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+T",
        "mac": "Command+Shift+T"
      },
      "description": "Open TimeCalc"
    }
  },

  "permissions": ["storage"]
}
